{
  "expo": {
    "name": "BizPulse",
    "slug": "bizpulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bizpulse",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0A2540"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bizpulse.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "BizPulse uses Face ID to securely unlock the app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A2540"
      },
      "package": "com.bizpulse.app",
      "permissions": ["USE_BIOMETRIC"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}
